{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "modulo-squares-prod",
          "appId": "1:253948321735:android:f947b74aee2ce4a79ec3e2",
          "fileOutput": "packages/mobile/android/app/google-services.prod.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "modulo-squares-prod",
          "appId": "1:253948321735:ios:527c4e69b233a2199ec3e2",
          "uploadDebugSymbols": false,
          "fileOutput": "packages/mobile/ios/Runner/GoogleService-Info.prod.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "modulo-squares-prod",
          "configurations": {
            "android": "1:253948321735:android:f947b74aee2ce4a79ec3e2",
            "ios": "1:253948321735:ios:527c4e69b233a2199ec3e2",
            "web": "1:253948321735:web:0f7df38ef2e47fe89ec3e2"
          }
        }
      }
    }
  },
  "functions": {
    "source": "packages/functions",
    "runtime": "nodejs22"
  },
  "firestore": {
    "rules": "packages/firestore-rules/firestore.rules"
  },
  "emulators": {
    "dataconnect": {
      "dataDir": "dataconnect/.dataconnect/pgliteData"
    }
  },
  "hosting": {
    "target": "website",
    "public": "packages/mobile/build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}