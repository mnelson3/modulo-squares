# Android signing configuration for local development
# Copy this file and update with your actual keystore details
# DO NOT commit this file to version control if it contains real credentials

# Keystore file path (relative to android/app/)
storeFile=upload-keystore.jks

# Keystore password
storePassword=your_keystore_password_here

# Key alias
keyAlias=upload

# Key password
keyPassword=your_key_password_here