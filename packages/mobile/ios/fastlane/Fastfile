# iOS Deployment with Fastlane
# This directory contains Fastlane configuration for automated iOS builds and deployments

# Install fastlane:
# gem install fastlane

# Usage:
# cd packages/mobile/ios
# fastlane beta  # Deploy to TestFlight
# fastlane release  # Deploy to App Store

# Fastfile
default_platform(:ios)

platform :ios do
  before_all do
    setup_ci if ENV['CI']
  end

  desc "Deploy a new version to TestFlight"
  lane :beta do
    # Skip App Store Connect API Key setup - using username/password with FASTLANE_PASSWORD
    # api_key = app_store_connect_api_key(
    #   key_id: ENV["ASC_KEY_ID"],
    #   issuer_id: ENV["ASC_ISSUER_ID"],
    #   key_filepath: "asc_private_key.p8"
    # )

    # Sync code signing certificates
    match(
      type: "appstore",
      readonly: true,
      username: ENV["FASTLANE_APPLE_ID"],
      git_branch: "main",
      app_identifier: "com.nelsongrey.modulosquares.app.ios"
    )

    # Clean bundler artifacts that shouldn't be tracked
    sh("rm -rf ../../.bundle ../../vendor")

    # Ensure clean git status (skip in CI as .env and keys are created)
    unless is_ci
      ensure_git_status_clean
    end

    # Increment build number
    increment_build_number

    # Install CocoaPods dependencies
    cocoapods(
      clean_install: true,
      repo_update: true
    )

    # Build the app
    build_app(
      scheme: "Runner",
      export_method: "app-store",
      export_team_id: ENV["FASTLANE_TEAM_ID"],
      codesigning_identity: "Apple Distribution",
      export_options: {
        provisioningProfiles: {
          "com.nelsongrey.modulosquares.app.ios" => "match AppStore com.nelsongrey.modulosquares.app.ios"
        }
      },
      output_directory: "./fastlane/builds",
      output_name: "ModuloSquares-beta",
      xcargs: "CODE_SIGN_STYLE=Manual PROVISIONING_PROFILE_SPECIFIER=\"match AppStore com.nelsongrey.modulosquares.app.ios\" FLUTTER_ROOT=\"$FLUTTER_ROOT\""
    )

    # Upload to TestFlight
    upload_to_testflight(
      username: ENV["FASTLANE_APPLE_ID"],
      beta_app_feedback_email: ENV["BETA_FEEDBACK_EMAIL"]
    )
  end

  desc "Deploy a new version to the App Store"
  lane :release do
    # Skip App Store Connect API Key setup - using username/password with FASTLANE_PASSWORD
    # api_key = app_store_connect_api_key(
    #   key_id: ENV["ASC_KEY_ID"],
    #   issuer_id: ENV["ASC_ISSUER_ID"],
    #   key_filepath: "asc_private_key.p8"
    # )

    # Sync code signing certificates
    match(
      type: "appstore",
      readonly: true,
      username: ENV["FASTLANE_APPLE_ID"],
      git_branch: "main",
      app_identifier: "com.nelsongrey.modulosquares.app.ios"
    )

    # Clean bundler artifacts that shouldn't be tracked
    sh("rm -rf ../../.bundle ../../vendor")

    # Ensure clean git status (skip in CI as .env and keys are created)
    unless is_ci
      ensure_git_status_clean
    end

    # Increment build number
    increment_build_number

    # Install CocoaPods dependencies
    cocoapods(
      clean_install: true,
      repo_update: true
    )

    # Build the app
    build_app(
      scheme: "Runner",
      export_method: "app-store",
      export_team_id: ENV["FASTLANE_TEAM_ID"],
      codesigning_identity: "Apple Distribution",
      export_options: {
        provisioningProfiles: {
          "com.nelsongrey.modulosquares.app.ios" => "match AppStore com.nelsongrey.modulosquares.app.ios"
        }
      },
      output_directory: "./fastlane/builds",
      output_name: "ModuloSquares-release",
      xcargs: "CODE_SIGN_STYLE=Manual PROVISIONING_PROFILE_SPECIFIER=\"match AppStore com.nelsongrey.modulosquares.app.ios\" FLUTTER_ROOT=\"$FLUTTER_ROOT\""
    )

    # Upload to App Store
    upload_to_app_store(
      username: ENV["FASTLANE_APPLE_ID"],
      force: true,
      reject_if_possible: true,
      skip_metadata: false,
      skip_screenshots: true,
      languages: ['en-US'],
      release_notes: {
        'en-US' => "Bug fixes and improvements"
      },
      submit_for_review: false,
      automatic_release: false,
      precheck_include_in_app_purchases: false
    )
  end

  desc "Initialize certificates and provisioning profiles"
  lane :init_certificates do
    # Generate development certificate
    match(
      type: "development",
      force: true
    )

    # Generate distribution certificate and provisioning profiles
    match(
      type: "appstore",
      force: true
    )
  end

  desc "Sync certificates and provisioning profiles"
  lane :sync_certificates do
    match(
      type: "appstore",
      readonly: true
    )
  end
end