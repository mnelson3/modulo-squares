# ZERO-TOUCH CERTIFICATE CONFIGURATION
# Optimized for maximum certificate reuse across all projects
# - Git storage enables sharing certificates between projects
# - force_for_new_devices ensures new devices are automatically added
# - skip_set_partition_list improves performance

git_url(ENV["MATCH_GIT_URL"])
git_branch("main")
storage_mode("git")
type("appstore")
username(ENV["FASTLANE_APPLE_ID"])
team_id(ENV["FASTLANE_TEAM_ID"])
keychain_name("fastlane_tmp_keychain")
keychain_password(ENV["MATCH_PASSWORD"])
force_for_new_devices(true)
skip_set_partition_list(true)