rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Leaderboards are read-only for clients. Writes are API-gated through Cloud Functions.
    match /modulo_leaderboard/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Daily leaderboard buckets are read-only for clients.
    match /modulo_daily_leaderboard/{challengeId}/scores/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Weekly leaderboard buckets are read-only for clients.
    match /modulo_weekly_leaderboard/{weekId}/scores/{document} {
      allow read: if true;
      allow write: if false;
    }

    // Purchases are server-authoritative. Clients can read their own records but cannot write.
    match /purchases/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    match /purchases/{userId}/transactions/{transactionId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // Entitlements are server-authoritative. Clients can only read their own document.
    match /entitlements/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // User profiles - users can read/write their own profile
    match /user_profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Game statistics - users can read/write their own stats
    match /game_stats/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User documents (gamertag, high score, etc.) - users own their document
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Gamertag uniqueness index - readable by all authenticated users (for
    // availability checks), writable only by the user whose UID matches the
    // document's uid field.
    match /gamertags/{tag} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow update: if false;
      allow delete: if false;
    }
  }
}