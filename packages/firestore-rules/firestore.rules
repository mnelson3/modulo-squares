rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Leaderboard collection - read access for all, write access for authenticated users only
    match /modulo_leaderboard/{document} {
      allow read: if true;
      allow create: if request.auth != null &&
        request.resource.data.keys().hasAll(['userId', 'score', 'level', 'timestamp']) &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.score is number &&
        request.resource.data.level is number &&
        request.resource.data.score >= 0 &&
        request.resource.data.level >= 1;
      allow update, delete: if false; // No updates or deletes allowed
    }

    // Purchases collection - only the user can read/write their own purchases
    match /purchases/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User profiles - users can read/write their own profile
    match /user_profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Game statistics - users can read/write their own stats
    match /game_stats/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}