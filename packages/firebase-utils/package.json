{
  "name": "@shared/firebase-utils",
  "version": "1.0.0",
  "description": "Shared Firebase utilities for Firebase-first architecture",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "clean": "rm -rf node_modules dist"
  },
  "dependencies": {
    "firebase": "^12.15.0",
    "firebase-admin": "^14.0.0",
    "protobufjs": "^8.6.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "firebase": "^12.15.0"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
