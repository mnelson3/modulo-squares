# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
.vscode/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
**/build/
*.dill.track.dill
.cache.dill.track.dill
**/*.dill.track.dill

# Android related
.cxx/
.cxx
.gradle/
**/android/app/build/
**/android/build/
**/android/.gradle/
local.properties

# iOS related
**/ios/Pods/
**/ios/Podfile.lock
**/ios/build/
**/ios/Flutter/ephemeral/
**/ios/Flutter/Generated.xcconfig
**/ios/Flutter/App.framework
**/ios/Flutter/Flutter.framework
**/ios/Flutter/Flutter.podspec
**/ios/Runner/GeneratedPluginRegistrant.*
**/ios/ServiceDefinitions.json

# Web related
**/web/build/
**/web/.dart_tool/

# Linux related
**/linux/build/
**/linux/.dart_tool/

# macOS related
**/macos/Pods/
**/macos/build/
**/macos/Flutter/ephemeral/
**/macos/Flutter/Generated.xcconfig
**/macos/Flutter/App.framework
**/macos/Flutter/Flutter.framework
**/macos/Flutter/Flutter.podspec
**/macos/Runner/GeneratedPluginRegistrant.*

# Windows related
**/windows/build/
**/windows/.dart_tool/

# Test cache
test_cache/
**/test_cache/
unit_test_assets/

# Firebase related
.firebase/
firebase-debug.log
firestore-debug.log

# Node.js (for monorepo)
**/node_modules/
**/package-lock.json
**/yarn.lock
**/.npm/
**/.yarn/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android signing configuration
packages/mobile/android/app/*.jks
packages/mobile/android/app/*.keystore
packages/mobile/android/local.properties

# iOS signing (generally handled by Xcode, but good to be safe)
packages/mobile/ios/*.mobileprovision
packages/mobile/ios/*.p12
node_modules

# Environment variables
.env
.env.*
!.env.example

# Act CLI secrets (DO NOT COMMIT real secrets)
.act-secrets/
!.act-secrets/test-secrets
!.act-secrets/secrets

# Self-hosted runner binaries (too large for Git)
actions-runner/externals/node*/bin/node
actions-runner/actions-runner-*.tar.gz

# Self-hosted runner working directory and artifacts
actions-runner/_work/
actions-runner/_diag/
actions-runner/.runner_migrated
