{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "modulo-squares-dev",
          "appId": "1:784677197785:android:d17a73b27367990061abc8",
          "fileOutput": "packages/mobile/android/app/google-services.dev.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "modulo-squares-dev",
          "appId": "1:784677197785:ios:51104e6b575616cc61abc8",
          "uploadDebugSymbols": false,
          "fileOutput": "packages/mobile/ios/Runner/GoogleService-Info.dev.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "modulo-squares-dev",
          "configurations": {
            "android": "1:784677197785:android:d17a73b27367990061abc8",
            "ios": "1:784677197785:ios:51104e6b575616cc61abc8",
            "web": "1:784677197785:web:17eec81cc847f1af61abc8"
          }
        }
      }
    }
  },
  "functions": {
    "source": "packages/functions",
    "runtime": "nodejs22"
  },
  "firestore": {
    "rules": "packages/firestore-rules/firestore.rules"
  },
  "emulators": {
    "dataconnect": {
      "dataDir": "dataconnect/.dataconnect/pgliteData"
    }
  },
  "hosting": {
    "target": "website",
    "public": "packages/web/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "camera=(), microphone=(), geolocation=(), payment=()"
          },
          {
            "key": "Strict-Transport-Security",
            "value": "max-age=31536000; includeSubDomains; preload"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          },
          {
            "key": "Pragma",
            "value": "no-cache"
          },
          {
            "key": "Expires",
            "value": "0"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}