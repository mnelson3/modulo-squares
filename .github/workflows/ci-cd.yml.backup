name: CI/CD Pipeline

on:
  push:
    branches: [ main, develop, staging ]
  pull_request:
    branches: [ main, develop, staging ]

env:
  FLUTTER_VERSION: '3.24.0'

jobs:
  test:
    name: Run Tests
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Setup Flutter
        uses: subosito/flutter-action@v2
        with:
          flutter-version: ${{ env.FLUTTER_VERSION }}
          cache: true

      - name: Install dependencies
        run: flutter pub get
        working-directory: packages/app

      - name: Run Flutter analyze
        run: flutter analyze
        working-directory: packages/app

      - name: Run tests
        run: flutter test --coverage
        working-directory: packages/app

      - name: Upload coverage to Codecov
        uses: codecov/codecov-action@v4
        with:
          file: packages/app/coverage/lcov.info
          flags: flutter
          name: codecov-umbrella

  build-and-deploy:
    name: Build and Deploy
    needs: test
    runs-on: ubuntu-latest
    if: github.event_name == 'push'
    environment:
      name: ${{ github.ref == 'refs/heads/main' && 'production' || github.ref == 'refs/heads/staging' && 'staging' || 'development' }}
      url: ${{ steps.deploy.outputs.url }}
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Setup Flutter
        uses: subosito/flutter-action@v2
        with:
          flutter-version: ${{ env.FLUTTER_VERSION }}
          cache: true

      - name: Setup Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '18'
          cache: 'npm'

      - name: Install Firebase CLI
        run: npm install -g firebase-tools

      - name: Install Flutter dependencies
        run: flutter pub get
        working-directory: packages/app

      - name: Build Flutter web app
        run: flutter build web --release --web-renderer canvaskit
        working-directory: packages/app

      - name: Setup Firebase project
        id: firebase-setup
        run: |
          case ${{ github.ref }} in
            refs/heads/main)
              echo "firebase_project=modulo-squares-prod" >> $GITHUB_OUTPUT
              echo "firebase_token=${{ secrets.FIREBASE_TOKEN_PRODUCTION }}" >> $GITHUB_OUTPUT
              ;;
            refs/heads/staging)
              echo "firebase_project=modulo-squares-staging" >> $GITHUB_OUTPUT
              echo "firebase_token=${{ secrets.FIREBASE_TOKEN_STAGING }}" >> $GITHUB_OUTPUT
              ;;
            refs/heads/develop)
              echo "firebase_project=modulo-squares-dev" >> $GITHUB_OUTPUT
              echo "firebase_token=${{ secrets.FIREBASE_TOKEN_DEVELOPMENT }}" >> $GITHUB_OUTPUT
              ;;
          esac

      - name: Deploy to Firebase Hosting
        id: deploy
        run: |
          firebase use ${{ steps.firebase-setup.outputs.firebase_project }} --token ${{ steps.firebase-setup.outputs.firebase_token }}
          firebase deploy --only hosting --token ${{ steps.firebase-setup.outputs.firebase_token }}
          echo "url=https://${{ steps.firebase-setup.outputs.firebase_project }}.web.app" >> $GITHUB_OUTPUT

      - name: Comment deployment URL on PR
        if: github.event_name == 'pull_request'
        uses: actions/github-script@v7
        with:
          script: |
            github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body: `🚀 **Deployment Preview**\n\n✅ Successfully deployed to: https://${{ steps.firebase-setup.outputs.firebase_project }}.web.app\n\n**Environment:** ${{ github.ref == 'refs/heads/main' && 'Production' || github.ref == 'refs/heads/staging' && 'Staging' || 'Development' }}\n\n**Build:** ${{ github.sha }}\n\n---\n\n*This deployment will be available for 7 days*`
            })

  release:
    name: Create Release
    needs: build-and-deploy
    runs-on: ubuntu-latest
    if: github.ref == 'refs/heads/main' && github.event_name == 'push'
    steps:
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Setup Flutter
        uses: subosito/flutter-action@v2
        with:
          flutter-version: ${{ env.FLUTTER_VERSION }}
          cache: true

      - name: Install Flutter dependencies
        run: flutter pub get
        working-directory: packages/app

      - name: Build Android APK
        run: flutter build apk --release
        working-directory: packages/app

      - name: Build Android AAB
        run: flutter build appbundle --release
        working-directory: packages/app

      - name: Build iOS (without codesign)
        run: flutter build ios --release --no-codesign
        working-directory: packages/app

      - name: Create Release
        id: create_release
        uses: actions/create-release@v1
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        with:
          tag_name: v${{ github.run_number }}
          release_name: Release v${{ github.run_number }}
          body: |
            ## 🚀 Release v${{ github.run_number }}

            ### Changes
            - Automated release from main branch
            - Build: ${{ github.sha }}

            ### Downloads
            - [Android APK](https://github.com/${{ github.repository }}/releases/download/v${{ github.run_number }}/app-release.apk)
            - [Android AAB](https://github.com/${{ github.repository }}/releases/download/v${{ github.run_number }}/app-release.aab)
          draft: false
          prerelease: false

      - name: Upload Android APK
        uses: actions/upload-release-asset@v1
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        with:
          upload_url: ${{ steps.create_release.outputs.upload_url }}
          asset_path: packages/app/build/app/outputs/flutter-apk/app-release.apk
          asset_name: app-release.apk
          asset_content_type: application/vnd.android.package-archive

      - name: Upload Android AAB
        uses: actions/upload-release-asset@v1
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        with:
          upload_url: ${{ steps.create_release.outputs.upload_url }}
          asset_path: packages/app/build/app/outputs/bundle/release/app-release.aab
          asset_name: app-release.aab
          asset_content_type: application/vnd.android.package-archive