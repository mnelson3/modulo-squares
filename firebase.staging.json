{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "modulo-squares-staging",
          "appId": "1:838061114925:android:9a9206d7065e2e3e229aa4",
          "fileOutput": "packages/app/android/app/google-services.json"
        }
      },
      "ios": {
        "default": {
          "projectId": "modulo-squares-staging",
          "appId": "1:838061114925:ios:f607167ffa35e7bb229aa4",
          "uploadDebugSymbols": false,
          "fileOutput": "packages/app/ios/Runner/GoogleService-Info.plist"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "modulo-squares-staging",
          "configurations": {
            "android": "1:838061114925:android:9a9206d7065e2e3e229aa4",
            "ios": "1:838061114925:ios:f607167ffa35e7bb229aa4",
            "web": "1:838061114925:web:4489f878453573b9229aa4"
          }
        }
      }
    }
  },
  "functions": {
    "source": "packages/functions",
    "runtime": "nodejs22"
  },
  "firestore": {
    "rules": "packages/firestore-rules/firestore.rules"
  },
  "emulators": {
    "dataconnect": {
      "dataDir": "dataconnect/.dataconnect/pgliteData"
    }
  },
  "hosting": {
    "target": "website",
    "public": "packages/app/build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}